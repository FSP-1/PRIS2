@startuml
title Enterprise MCP + OpenWebUI + vLLM + Microsoft OAuth

skinparam backgroundColor #ffffff
skinparam componentStyle rectangle
skinparam shadowing false
skinparam ArrowColor #2b2b2b
skinparam packageStyle rectangle

actor "Usuario\nBrowser corporativo" as USER

package "Red Interna Empresa (192.168.2.0/24)" {

  node "Open WebUI\n192.168.2.15:8080" as OPENWEB

  node "vLLM Server\nLLM local" as VLLM

  node "NGINX Reverse Proxy\n192.168.2.15:443\nHTTPS + OAuth Callback" as NGINX
}

package "Red Servicios / DMZ (10.10.10.0/24)" {

  node "MS-365 MCP Server\n10.10.10.104:3000\nStreamable HTTP MCP" as MCP
}

cloud "Microsoft Entra ID\nOAuth 2.1" as ENTRA

cloud "Microsoft Graph API\nOutlook / Calendar / SharePoint" as GRAPH

' =====================
' USER FLOW
' =====================

USER --> OPENWEB :
HTTPS\nChat UI

OPENWEB --> VLLM :
OpenAI-compatible API\nTool Calling

VLLM --> OPENWEB :
Tool Request

' =====================
' MCP FLOW
' =====================

OPENWEB --> NGINX :
HTTPS /mcp

NGINX --> MCP :
HTTP proxy_pass\nstreamable-http MCP

' =====================
' OAUTH FLOW
' =====================

MCP --> USER :
302 Redirect\n/login

USER --> ENTRA :
OAuth Login + MFA

ENTRA --> USER :
Redirect callback\nhttps://openweb.company.com/callback

USER --> OPENWEB :
OAuth callback

OPENWEB --> NGINX :
Authenticated MCP calls

NGINX --> MCP :
Bearer Token MCP Request

' =====================
' GRAPH FLOW
' =====================

MCP --> GRAPH :
Microsoft Graph API\nMail.Read\nCalendars.Read

GRAPH --> MCP :
Emails / Calendar / Sites

MCP --> OPENWEB :
Tool Results

OPENWEB --> VLLM :
Tool Response Context

VLLM --> OPENWEB :
Final Answer

OPENWEB --> USER :
Chat Response

' =====================
' NOTES
' =====================

note right of MCP
- Internal only
- No public Internet exposure
- OAuth handled server-side
- Scoped Graph permissions
end note

note bottom of VLLM
Local inference only
No company data leaves infra
end note

note right of ENTRA
Conditional Access
MFA
Device Compliance
Enterprise SSO
end note

@enduml
